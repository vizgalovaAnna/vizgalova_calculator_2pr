<Window x:Class="vizgalova_calculator_2pr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="400" Width="309" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FF83C6EA">

    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB0C4DE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FFA2E7EC" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Background="White" BorderBrush="Blue" BorderThickness="2" Margin="5" CornerRadius="5">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ExpressionText" Text="" FontSize="14" Foreground="Gray" HorizontalAlignment="Right" Margin="10,5,10,0"/>
                <TextBlock x:Name="ResultText" Text="0" FontSize="32" HorizontalAlignment="Right" Margin="10,0,10,5"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="(" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content=")" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="^" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>

            <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>

            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>

            <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Style="{StaticResource ButtonStyle}" Background="#FF90A7F1" Click="Button_Click"/>

            <Button Grid.Row="4" Grid.Column="0" Content="C" Style="{StaticResource ButtonStyle}" Background="#FF657CFF" Click="Button_Click"/>
            <Button Grid.Row="4" Grid.Column="1" Content="0" Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." Style="{StaticResource ButtonStyle}" Background="#FFBBD3F3" Click="Button_Click"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" Style="{StaticResource ButtonStyle}" Background="#FF657CFF" Click="Button_Click"/>
        </Grid>
    </Grid>
</Window>
    